{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true
  },
  "include": [
    "pages/reports/**/*.ts",
    "pages/reports/**/*.tsx",
    "components/reports/**/*.ts",
    "components/reports/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "server"
  ]
}
